<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - CoworkingApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/CoworkingApp.styles.css" asp-append-version="true"/>
    @* <link rel="stylesheet" href="https://unpkg.com/mvp.css"> *@
    @* <link rel="stylesheet" href="https://cdn.simplecss.org/simple.css"> *@
    @* <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@picocss/pico@2/css/pico.min.css"> *@
    @* <link rel="stylesheet" href="~/css/mi.css" /> *@
    <link rel="stylesheet" href="~/css/sakura.css" />
    @* <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/yegor256/tacit@gh-pages/tacit-css-1.8.1.min.css"/> *@
</head>
<body>

<header>
    <nav>
        <a asp-area="" asp-controller="Home" asp-action="Index">CoworkingApp</a>
        <ul>
            <li><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
            <li><a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
            <li><a asp-area="" asp-controller="AuthApi" asp-action="Register">Register</a></li>
            <li><a asp-area="" asp-controller="AuthApi" asp-action="Login">Login</a></li>
        </ul>
    </nav>
</header>

<main role="main">
    @RenderBody()
</main>

<footer>
    &copy; 2025 - CoworkingApp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>