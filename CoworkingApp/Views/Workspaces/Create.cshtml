@model CoworkingApp.Models.DTOModels.Workspace.WorkspaceCreateRequestDto

<title>Create Workspace</title>
<h1>Create Workspace</h1>

<form method="post" asp-action="Create">
    <label asp-for="Name">Name:</label>
    <input type="text" asp-for="Name" />
   
    <br /> 
    
    <label asp-for="Description">Description</label>
    <input type="text" asp-for="Description" />

    <br />
    
    <label asp-for="StatusId"></label>
    <select asp-for="StatusId" asp-items="ViewBag.Statuses">
        <option value="">
            -- Select Workspace Status --
        </option>
    </select>
    
    <br />
    
    <label asp-for="CoworkingCenterId"></label>
    <select asp-for="CoworkingCenterId" asp-items="ViewBag.CoworkingCenters">
        <option value="">
            -- Select Coworking Center --
        </option>
    </select>
    
    <br />
    
    <button type="submit">Create</button>
</form>
